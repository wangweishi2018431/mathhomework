page {
  background: #f4f7fb;
}

.container {
  padding: 20rpx;
  padding-bottom: 60rpx;
}

.hero {
  padding: 20rpx 16rpx 12rpx;
}

.hero-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #1f2d3d;
}

.hero-sub {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #66788a;
}

/* 卡片样式 */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(10, 26, 47, 0.06);
}

.card-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2d3d;
  margin-bottom: 16rpx;
}

.hint {
  display: block;
  font-size: 24rpx;
  color: #7b8794;
  margin-bottom: 16rpx;
}

.input {
  width: 100%;
  box-sizing: border-box;
  border: 2rpx solid #d8e0ea;
  border-radius: 12rpx;
  padding: 18rpx 20rpx;
  background: #fff;
  font-size: 28rpx;
  color: #1f2d3d;
  margin-bottom: 16rpx;
}

.field-label {
  display: block;
  font-size: 26rpx;
  color: #334e68;
  margin-top: 12rpx;
  margin-bottom: 8rpx;
  font-weight: 500;
}

/* 按钮 */
.primary-btn,
.secondary-btn,
.danger-btn {
  border: none;
  border-radius: 12rpx;
  font-size: 28rpx;
  margin-bottom: 16rpx;
}

.primary-btn::after,
.secondary-btn::after,
.danger-btn::after {
  border: none;
}

.primary-btn {
  background: linear-gradient(135deg, #2c9678 0%, #33b18f 100%);
  color: #fff;
}

.primary-btn.loading {
  opacity: 0.7;
}

.secondary-btn {
  background: #eef2f7;
  color: #334e68;
}

.danger-btn {
  background: #ffe6e6;
  color: #d64545;
}

/* 登录卡片 */
.login-card {
  text-align: center;
  padding: 40rpx;
}

/* 状态卡片 */
.status-card {
  background: linear-gradient(135deg, #f8fafc 0%, #ffffff 100%);
}

.status-item {
  display: flex;
  align-items: center;
  padding: 16rpx;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  background: #f8fafc;
}

.status-item.ok {
  background: #e8f5f0;
}

.status-item.warn {
  background: #fff3e0;
}

.status-icon {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  border-radius: 50%;
  font-size: 28rpx;
  margin-right: 16rpx;
}

.status-item.ok .status-icon {
  background: #2c9678;
  color: #fff;
}

.status-item.warn .status-icon {
  background: #ff9800;
  color: #fff;
}

.status-info {
  flex: 1;
}

.status-label {
  display: block;
  font-size: 26rpx;
  color: #334e68;
  font-weight: 500;
}

.status-value {
  display: block;
  font-size: 24rpx;
  color: #7b8794;
  margin-top: 4rpx;
}

/* 操作卡片 */
.action-card {
  padding: 24rpx;
}

.action-card button {
  margin-bottom: 16rpx;
}

.action-card button:last-child {
  margin-bottom: 0;
}

/* 结果提示 */
.toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  padding: 24rpx 40rpx;
  border-radius: 12rpx;
  opacity: 0;
  transition: opacity 0.3s;
  pointer-events: none;
  z-index: 1000;
}

.toast.show {
  opacity: 1;
}

.toast.success {
  background: #2c9678;
  color: #fff;
}

.toast.error {
  background: #d64545;
  color: #fff;
}

/* 题目求解专用配置卡片 */
.solve-card {
  background: linear-gradient(135deg, #faf9ff 0%, #f5f3ff 100%);
  border-left: 6rpx solid #7c3aed;
}

/* 模型选择器 */
.model-selector {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.model-picker {
  flex: 1;
  border: 2rpx solid #d8e0ea;
  border-radius: 12rpx;
  background: #fff;
  padding: 18rpx 20rpx;
}

.model-picker.disabled {
  background: #f5f5f5;
  border-style: dashed;
}

.picker-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.picker-text {
  font-size: 28rpx;
  color: #1f2d3d;
}

.picker-arrow {
  font-size: 24rpx;
  color: #7b8794;
}

.model-picker.disabled .picker-text {
  color: #9aa6b2;
}

.fetch-btn {
  background: #e8f5f0;
  color: #2c9678;
  border: none;
  border-radius: 10rpx;
  padding: 0 24rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 26rpx;
  min-width: 140rpx;
}

.fetch-btn::after {
  border: none;
}

.fetch-btn.loading {
  opacity: 0.7;
}

.model-desc {
  display: block;
  font-size: 24rpx;
  color: #7b8794;
  margin-top: 4rpx;
  padding-left: 4rpx;
}
