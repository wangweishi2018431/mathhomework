<view class="container">
  <view class="hero">
    <text class="hero-title">教师管理台</text>
    <text class="hero-sub">课程管理 · 创建作业</text>
  </view>

  <!-- Tab 切换 -->
  <view class="tab-bar">
    <view class="tab-item {{activeTab === 'course' ? 'active' : ''}}" bindtap="switchTab" data-tab="course">
      <text class="tab-icon">📚</text>
      <text class="tab-text">课程管理</text>
    </view>
    <view class="tab-item {{activeTab === 'assignment' ? 'active' : ''}}" bindtap="switchTab" data-tab="assignment">
      <text class="tab-icon">✏️</text>
      <text class="tab-text">创建作业</text>
    </view>
    <view class="tab-item" bindtap="goToAdmin">
      <text class="tab-icon">⚙️</text>
      <text class="tab-text">设置</text>
    </view>
  </view>

  <!-- Tab 1: 课程管理 -->
  <view class="tab-content" wx:if="{{activeTab === 'course'}}">
    <!-- 创建课程 -->
    <view class="card">
      <text class="card-title">创建课程</text>
      <input class="input" placeholder="课程编号（如 MATH201）" value="{{courseIdInput}}" data-key="courseIdInput" bindinput="onFieldInput" />
      <input class="input" placeholder="课程名称（如 高等数学A）" value="{{courseNameInput}}" data-key="courseNameInput" bindinput="onFieldInput" />
      <button class="primary-btn" bindtap="createCourse">创建课程</button>
    </view>

    <!-- 选择课程 -->
    <view class="card">
      <view class="row-between">
        <text class="card-title">选择课程</text>
        <text class="hint" wx:if="{{loadingCourses}}">加载中...</text>
      </view>

      <picker mode="selector" range="{{courses}}" range-key="course_name" value="{{selectedCourseIndex}}" bindchange="onCoursePickerChange">
        <view class="picker {{courses.length ? '' : 'disabled'}}">
          {{courses.length ? (selectedCourseName + '（' + selectedCourseId + '）') : '暂无课程，请先创建'}}
        </view>
      </picker>
    </view>

    <!-- 花名册管理 -->
    <view class="card" wx:if="{{selectedCourseId}}">
      <text class="card-title">花名册管理</text>

      <input class="input" placeholder="学号" value="{{studentIdInput}}" data-key="studentIdInput" bindinput="onFieldInput" />
      <input class="input" placeholder="学生姓名" value="{{studentNameInput}}" data-key="studentNameInput" bindinput="onFieldInput" />
      <input class="input" placeholder="班级（可选）" value="{{classNameInput}}" data-key="classNameInput" bindinput="onFieldInput" />

      <button class="primary-btn" bindtap="addStudent">添加学生</button>

      <view class="divider"></view>

      <view class="row-between">
        <button class="secondary-btn" bindtap="chooseRosterFile">选择名单文件</button>
        <button class="primary-btn compact" bindtap="importStudents">批量导入</button>
      </view>
      <text class="hint" wx:if="{{importFileName}}">已选择：{{importFileName}}</text>

      <view class="student-list">
        <view class="student-row" wx:for="{{rosterStudents}}" wx:key="student_id">
          <view class="student-meta">
            <text class="student-name">{{item.name}}</text>
            <text class="student-sub">{{item.student_id}}{{item.class_name ? (' · ' + item.class_name) : ''}}</text>
          </view>
          <button class="danger-btn" size="mini" data-sid="{{item.student_id}}" bindtap="removeStudent">移除</button>
        </view>

        <view class="empty" wx:if="{{!rosterStudents.length}}">
          当前课程还没有学生
        </view>
      </view>
    </view>
  </view>

  <!-- Tab 2: 创建作业 -->
  <view class="tab-content" wx:if="{{activeTab === 'assignment'}}">
    <!-- 子 Tab 切换 -->
    <view class="sub-tab-bar" wx:if="{{!assignmentMode}}">
      <view class="sub-tab-item {{assignmentSubTab === 'list' ? 'active' : ''}}" bindtap="switchAssignmentSubTab" data-subtab="list">
        <text class="sub-tab-text">作业列表</text>
      </view>
      <view class="sub-tab-item {{assignmentSubTab === 'create' ? 'active' : ''}}" bindtap="switchAssignmentSubTab" data-subtab="create">
        <text class="sub-tab-text">创建作业</text>
      </view>
    </view>

    <!-- 作业列表 -->
    <view wx:if="{{!assignmentMode && assignmentSubTab === 'list'}}">
      <view class="assignment-list">
        <view class="assignment-card" wx:for="{{assignments}}" wx:key="id">
          <view class="assignment-header">
            <text class="assignment-title">{{item.title}}</text>
            <view class="status-badge {{item.statusClass}}">{{item.statusText}}</view>
          </view>

          <view class="assignment-meta">
            <text class="meta-item">题目：{{item.question_count}}题</text>
            <text class="meta-item">满分：{{item.total_score}}分</text>
          </view>

          <view class="assignment-progress">
            <view class="progress-header">
              <text class="progress-label">提交进度</text>
              <text class="progress-value">{{item.progress || '0/0'}}</text>
            </view>
            <view class="progress-bar">
              <view class="progress-fill" style="width: {{item.progressPercent}}%"></view>
            </view>
          </view>

          <view class="assignment-time">
            <view class="time-row">
              <text class="time-label">开始：</text>
              <text class="time-value">{{item.submit_start_time || '未设置'}}</text>
            </view>
            <view class="time-row">
              <text class="time-label">截止：</text>
              <text class="time-value {{item.isNearDeadline ? 'near-deadline' : ''}}">{{item.submit_end_time || '未设置'}}</text>
            </view>
            <view class="time-row" wx:if="{{item.appeal_end_time}}">
              <text class="time-label">申诉：</text>
              <text class="time-value">{{item.appeal_end_time}}</text>
            </view>
          </view>

          <view class="assignment-rules">
            <text class="rule-tag" wx:if="{{item.allow_resubmit}}">可订正</text>
            <text class="rule-tag" wx:if="{{item.allow_late}}">可逾期</text>
            <text class="rule-tag late-rule">逾期{{item.late_score_rule}}计分</text>
          </view>

          <view class="assignment-actions">
            <button class="action-btn secondary" size="mini" data-id="{{item.id}}" bindtap="viewAssignmentDetail">查看详情</button>
            <button class="action-btn primary" size="mini" data-id="{{item.id}}" data-endtime="{{item.submit_end_time}}" bindtap="showExtendDeadline" wx:if="{{item.status !== 'closed'}}">延长截止</button>
          </view>
        </view>

        <view class="empty-state" wx:if="{{!assignments.length}}">
          <text class="empty-icon">📝</text>
          <text class="empty-title">暂无作业</text>
          <text class="empty-desc">点击"创建作业"开始布置第一份作业</text>
        </view>
      </view>
    </view>

    <!-- 选择输入模式 -->
    <view class="mode-selector" wx:if="{{!assignmentMode && assignmentSubTab === 'create'}}">
      <text class="section-title">选择创建方式</text>
      <view class="mode-cards">
        <view class="mode-card" bindtap="selectAssignmentMode" data-mode="manual">
          <text class="mode-icon">⌨️</text>
          <text class="mode-title">手动输入</text>
          <text class="mode-desc">直接输入题目内容和标准答案</text>
        </view>
        <view class="mode-card" bindtap="selectAssignmentMode" data-mode="photo">
          <text class="mode-icon">📷</text>
          <text class="mode-title">拍照上传</text>
          <text class="mode-desc">上传练习册/试卷图片，AI识别题目</text>
        </view>
      </view>
    </view>

    <!-- 模式选择后的内容 -->
    <view wx:if="{{assignmentMode}}">
      <!-- 返回按钮 -->
      <view class="mode-header">
        <text class="mode-tag">{{assignmentMode === 'manual' ? '手动输入模式' : '拍照上传模式'}}</text>
        <button class="text-btn" bindtap="resetAssignmentMode">切换方式</button>
      </view>

      <!-- 公共：作业标题和时间配置 -->
      <view class="card">
        <text class="card-title">作业标题</text>
        <input class="input" placeholder="如：第一章总练习题" value="{{assignmentTitle}}" data-key="assignmentTitle" bindinput="onFieldInput" />

        <text class="card-title" style="margin-top: 24rpx;">时间配置</text>

        <text class="field-label">提交开始时间</text>
        <picker mode="multiSelector" range="{{dateTimeArray}}" value="{{dateTimeStart}}" bindchange="onStartTimeChange" bindcolumnchange="onStartTimeColumnChange">
          <view class="picker {{assignmentStartTime ? '' : 'disabled'}}">
            {{assignmentStartTime || '选择开始时间'}}
          </view>
        </picker>

        <text class="field-label">提交截止时间</text>
        <picker mode="multiSelector" range="{{dateTimeArray}}" value="{{dateTimeEnd}}" bindchange="onEndTimeChange" bindcolumnchange="onEndTimeColumnChange">
          <view class="picker {{assignmentEndTime ? '' : 'disabled'}}">
            {{assignmentEndTime || '选择截止时间'}}
          </view>
        </picker>

        <text class="field-label">申诉截止时间（可选）</text>
        <picker mode="multiSelector" range="{{dateTimeArray}}" value="{{dateTimeAppeal}}" bindchange="onAppealTimeChange" bindcolumnchange="onAppealTimeColumnChange">
          <view class="picker {{assignmentAppealTime ? '' : 'disabled'}}">
            {{assignmentAppealTime || '选择申诉截止时间（可选）'}}
          </view>
        </picker>
      </view>

      <!-- 规则配置 -->
      <view class="card">
        <text class="card-title">规则配置</text>

        <view class="switch-row">
          <text class="switch-label">允许订正重交</text>
          <switch checked="{{allowResubmit}}" bindchange="onAllowResubmitChange" color="#2c9678" />
        </view>

        <view class="switch-row">
          <text class="switch-label">允许逾期提交</text>
          <switch checked="{{allowLate}}" bindchange="onAllowLateChange" color="#2c9678" />
        </view>

        <text class="field-label" wx:if="{{allowLate}}">逾期计分规则</text>
        <picker wx:if="{{allowLate}}" mode="selector" range="{{lateRules}}" value="{{lateRuleIndex}}" bindchange="onLateRuleChange">
          <view class="picker">
            {{lateRules[lateRuleIndex]}}
          </view>
        </picker>
      </view>

      <!-- 模式A: 手动输入 -->
      <view wx:if="{{assignmentMode === 'manual'}}">
        <view class="card">
          <text class="card-title">题目内容</text>
          <textarea class="textarea" placeholder="输入题目内容（支持 LaTeX）" value="{{questionContent}}" data-key="questionContent" bindinput="onFieldInput" />
          <input class="input" type="digit" placeholder="满分（默认10）" value="{{maxScoreInput}}" data-key="maxScoreInput" bindinput="onFieldInput" />
        </view>

        <view class="card">
          <text class="card-title">标准答案</text>
          <textarea class="textarea" placeholder="输入标准答案（支持 LaTeX）" value="{{teacherAnswer}}" data-key="teacherAnswer" bindinput="onFieldInput" />
        </view>

        <button class="primary-btn submit-btn" bindtap="createAssignmentManual">创建作业</button>
      </view>

      <!-- 模式B: 拍照上传 -->
      <view wx:if="{{assignmentMode === 'photo'}}">
        <view class="card">
          <text class="card-title">上传题目图片</text>
          <text class="hint">支持练习册、试卷等包含多题的图片</text>

          <view class="image-upload-area" bindtap="chooseSolveImage">
            <image wx:if="{{solveImagePreview}}" src="{{solveImagePreview}}" mode="aspectFit" class="preview-image" />
            <view wx:else class="upload-placeholder">
              <text class="upload-icon">📷</text>
              <text class="upload-text">点击选择/拍摄图片</text>
            </view>
          </view>

          <text class="card-title">指定要创建的题目</text>
          <text class="hint">例如：第一大题第3小题，第三大题</text>
          <input class="input" placeholder="题目指定" value="{{solveSpecifications}}" bindinput="onSolveSpecInput" />

          <button class="primary-btn {{solveLoading ? 'loading' : ''}}" bindtap="solveAndExtractQuestion" disabled="{{solveLoading}}">
            {{solveLoading ? 'AI识别中...' : '识别题目并创建'}}
          </button>
        </view>

        <!-- 识别结果编辑区 -->
        <view class="card result-card" wx:if="{{extractedQuestion}}">
          <view class="result-header">
            <text class="card-title">AI识别结果（请核对修改）</text>
            <text class="edit-hint">可编辑</text>
          </view>

          <view class="info-row">
            <text class="info-label">题型：</text>
            <text class="info-value">{{extractedQuestion.question_type}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">难度：</text>
            <text class="info-value">{{extractedQuestion.difficulty}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">知识点：</text>
            <text class="info-value">{{extractedQuestion.knowledge_points_str}}</text>
          </view>

          <view class="divider"></view>

          <text class="field-label">题目内容（可编辑）</text>
          <textarea class="textarea" value="{{extractedQuestion.content}}" data-key="extractedContent" bindinput="onExtractedFieldInput" />

          <text class="field-label">标准答案（可编辑）</text>
          <textarea class="textarea" value="{{extractedQuestion.full_solution}}" data-key="extractedAnswer" bindinput="onExtractedFieldInput" />

          <text class="field-label">满分</text>
          <input class="input" type="digit" value="{{extractedQuestion.max_score || 10}}" data-key="extractedMaxScore" bindinput="onExtractedFieldInput" />

          <button class="primary-btn submit-btn" bindtap="createAssignmentFromPhoto">确认并创建作业</button>
        </view>
      </view>

      <!-- 创建成功提示 -->
      <view class="card success-card" wx:if="{{createdAssignment}}">
        <view class="success-icon">✓</view>
        <text class="success-title">作业创建成功</text>
        <text class="success-text">{{createdAssignment.title}}</text>
        <text class="success-id">ID: {{createdAssignment.id}}</text>
        <button class="secondary-btn" bindtap="copyAssignmentId">复制作业ID</button>
        <button class="text-btn" bindtap="createAnotherAssignment">继续创建</button>
      </view>
    </view>
  </view>
</view>
