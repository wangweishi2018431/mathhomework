page {
  background: #f4f7fb;
}

.container {
  padding: 20rpx;
  padding-bottom: 160rpx;
}

.result-header {
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(10, 26, 47, 0.06);
}

.result-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1f2d3d;
}

.score-badge {
  display: flex;
  align-items: baseline;
  background: linear-gradient(135deg, #2c9678 0%, #33b18f 100%);
  padding: 16rpx 32rpx;
  border-radius: 50rpx;
}

.score-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
}

.score-total {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-left: 8rpx;
}

.questions-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.question-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(10, 26, 47, 0.06);
}

.question-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f4f8;
}

.q-num {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2d3d;
}

.status-tag {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.status-tag.correct {
  background: #e8f5f0;
  color: #2c9678;
}

.status-tag.partial {
  background: #fff3e0;
  color: #f57c00;
}

.status-tag.wrong {
  background: #ffe6e6;
  color: #d64545;
}

.score-row {
  margin-bottom: 24rpx;
}

.score-text {
  font-size: 28rpx;
  color: #334e68;
  font-weight: 500;
  display: block;
  margin-bottom: 12rpx;
}

.score-bar-container {
  height: 12rpx;
  background: #f0f4f8;
  border-radius: 6rpx;
  overflow: hidden;
}

.score-bar-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.3s;
}

.score-bar-fill.correct {
  background: #2c9678;
}

.score-bar-fill.partial {
  background: #f57c00;
}

.score-bar-fill.wrong {
  background: #d64545;
}

.content-section, .analysis-section {
  margin-top: 20rpx;
  padding: 20rpx;
  background: #f8fafc;
  border-radius: 12rpx;
}

.analysis-section {
  background: #fff9e6;
  border-left: 6rpx solid #f57c00;
}

.section-label {
  font-size: 26rpx;
  color: #7b8794;
  display: block;
  margin-bottom: 12rpx;
}

.section-content {
  font-size: 28rpx;
  color: #334e68;
  line-height: 1.6;
}

.empty-state {
  text-align: center;
  padding: 100rpx 40rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #7b8794;
}

.footer-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.back-btn {
  width: 100%;
  background: #f0f4f8;
  color: #334e68;
  font-size: 28rpx;
  padding: 24rpx 0;
  border-radius: 12rpx;
}

.back-btn::after {
  border: none;
}
